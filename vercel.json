{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm --prefix backend ci && npm --prefix frontend ci",
  "buildCommand": "npm --prefix backend run build && npm --prefix frontend run build",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "backend/src/main.ts"
    },
    {
      "src": "/api/socket/(.*)",
      "dest": "backend/src/main.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/src/main.ts"
    },
    {
      "src": "/backend-auth/(.*)",
      "dest": "backend/src/main.ts"
    },
    {
      "src": "/auth/(.*)",
      "dest": "backend/src/main.ts"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
