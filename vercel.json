{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/api/$1"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/backend/auth/$1"
        }
    ],
    "builds": [
        {
            "src": "backend/src/main.ts",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/next"
        }
    ]
}