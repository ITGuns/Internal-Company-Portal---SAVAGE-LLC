DATABASE_URL=postgresql://user:password@localhost:5432/portal
REDIS_URL=redis://localhost:6379
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
DISCORD_CLIENT_ID=<your-discord-client-id>
DISCORD_CLIENT_SECRET=<your-discord-client-secret>
JWT_SECRET=<replace-with-secret>
FRONTEND_URL=http://localhost:3000


# Email Service Configuration
EMAIL_ENABLED=false
EMAIL_PROVIDER=sendgrid

# Email From Settings
EMAIL_FROM_ADDRESS=noreply@savage-llc.com
EMAIL_FROM_NAME=SAVAGE LLC Internal Portal

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email Features
DAILY_DIGEST_ENABLED=true
DAILY_DIGEST_TIME=09:00
DAILY_DIGEST_TIMEZONE=Asia/Manila
