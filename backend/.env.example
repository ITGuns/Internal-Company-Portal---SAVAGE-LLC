DATABASE_URL=postgresql://user:password@localhost:5432/portal
REDIS_URL=redis://localhost:6379
TRUST_PROXY_HOPS=0
SEED_DEFAULT_PASSWORD=<local-seed-password-min-12-chars>
AUTH_RATE_LIMIT_STORE=memory
AUTH_RATE_LIMIT_REDIS_PREFIX=portal:auth-rate-limit
ENABLE_SOCKET_REDIS_ADAPTER=false
COMMERCIAL_READINESS_MODE=false
AUTH_RATE_LIMIT_LOGIN_LIMIT=10
AUTH_RATE_LIMIT_LOGIN_WINDOW_MS=900000
AUTH_RATE_LIMIT_SIGNUP_LIMIT=5
AUTH_RATE_LIMIT_SIGNUP_WINDOW_MS=3600000
AUTH_RATE_LIMIT_FORGOT_PASSWORD_LIMIT=5
AUTH_RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MS=3600000
AUTH_RATE_LIMIT_RESET_PASSWORD_LIMIT=5
AUTH_RATE_LIMIT_RESET_PASSWORD_WINDOW_MS=3600000
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
DISCORD_CLIENT_ID=<your-discord-client-id>
DISCORD_CLIENT_SECRET=<your-discord-client-secret>
JWT_SECRET=<replace-with-secret>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=<replace-with-different-secret>
REFRESH_TOKEN_EXPIRES_IN=30d
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
OPS_MANAGER_EMAIL=ops-manager@example.com

UPLOAD_STORAGE_DRIVER=local
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=auto
UPLOAD_S3_ENDPOINT=
UPLOAD_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email Service Configuration
EMAIL_ENABLED=false
EMAIL_PROVIDER=sendgrid

# Email From Settings
EMAIL_FROM_ADDRESS=noreply@savage-llc.com
EMAIL_FROM_NAME=SAVAGE LLC Internal Portal

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email Features
DAILY_DIGEST_ENABLED=true
DAILY_DIGEST_TIME=09:00
DAILY_DIGEST_TIMEZONE=Asia/Manila
