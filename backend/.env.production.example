NODE_ENV=production
PORT=4000

# Runtime database connection used by the backend application.
# For Supabase serverless-style deployments, use the transaction pooler URL.
DATABASE_URL=postgresql://prisma.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public

# Migration/bootstrap connection used by Prisma CLI.
# For Supabase, use the session pooler or direct connection URL.
DIRECT_DATABASE_URL=postgresql://prisma.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?schema=public

REDIS_URL=redis://redis:6379
AUTH_RATE_LIMIT_STORE=redis
AUTH_RATE_LIMIT_REDIS_PREFIX=portal:auth-rate-limit
TRUST_PROXY_HOPS=1
LOG_LEVEL=info

JWT_SECRET=<replace-with-strong-secret>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=<replace-with-different-strong-secret>
REFRESH_TOKEN_EXPIRES_IN=30d

FRONTEND_URL=https://mydeskii.com
CORS_ORIGIN=https://mydeskii.com
OPS_MANAGER_EMAIL=ops-manager@example.com
ADMIN_EMAILS=

EMAIL_ENABLED=false
EMAIL_PROVIDER=sendgrid
EMAIL_FROM_ADDRESS=noreply@savage-llc.com
EMAIL_FROM_NAME=SAVAGE LLC Internal Portal
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
