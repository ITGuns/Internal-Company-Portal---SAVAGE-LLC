{
  "name": "portal-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "ts-node tests/run-tests.ts",
    "build": "tsc -p tsconfig.json",
    "prisma:generate": "dotenv -e .env -- prisma generate",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e .env -- prisma migrate deploy",
    "prisma:deploy:production": "dotenv -e .env.production -- prisma migrate deploy",
    "prisma:deploy:render": "prisma migrate deploy",
    "prisma:bootstrap:render": "node scripts/bootstrap-production-database.mjs",
    "prisma:bootstrap-production": "dotenv -e .env.production -- node scripts/bootstrap-production-database.mjs",
    "prisma:studio": "dotenv -e .env -- prisma studio",
    "prisma:reset": "dotenv -e .env -- prisma migrate reset",
    "prisma:seed": "dotenv -e .env -- ts-node prisma/seed.ts",
    "seed:client-service-tiers": "dotenv -e .env -- ts-node prisma/seed-client-service-tiers.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.8",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.18.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^7.0.9",
    "@types/passport": "^1.0.17",
    "@types/passport-discord": "^0.1.15",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.16.0",
    "@types/socket.io": "^3.0.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.4.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.6"
  },
  "overrides": {
    "@hono/node-server": "1.19.14"
  }
}
