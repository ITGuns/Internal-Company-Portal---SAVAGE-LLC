datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  avatar    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  roles     UserRole[]
  tasks     Task[]

  @@index([email])
}

model Department {
  id        String     @id @default(uuid())
  name      String     @unique
  driveId   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tasks     Task[]
  userRoles UserRole[]

  @@index([name])
}

model Task {
  id           String      @id @default(uuid())
  title        String
  description  String?
  status       String      @default("todo")
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  departmentId String?
  assignee     User?       @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([departmentId])
  @@index([assigneeId])
}

model UserRole {
  id           String      @id @default(uuid())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  role         String
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId String?
  createdAt    DateTime    @default(now())

  @@unique([userId, departmentId, role])
  @@index([userId])
  @@index([departmentId])
}
