// This is your Prisma schema file for Prisma v7.4.0
// Learn more: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// ============================================
// CORE MODELS
// ============================================

model User {
    id     String  @id @default(cuid())
    email  String  @unique
    name   String?
    avatar String?

    // Profile fields (added in migration 20260217105259)
    phone       String?
    address     String?
    city        String?
    citizenship String?
    birthday    DateTime?

    // Auth & Access Control
    password   String?
    isApproved Boolean @default(false)

    // Employee Workflow fields
    status      String    @default("active")
    appliedDate DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    tasks                Task[]
    roles                UserRole[]
    announcements        Announcement[]
    dailyLogs            DailyLog[]
    timeEntries          TimeEntry[]
    announcementLikes    AnnouncementLike[]
    announcementComments AnnouncementComment[]
    announcementRSVPs    AnnouncementRSVP[]
    dailyLogLikes        DailyLogLike[]
    participants         Participant[]
    messages             Message[]
    employeeProfile      EmployeeProfile?
    payslips             Payslip[]

    @@index([email])
}

model Department {
    id        String   @id @default(cuid())
    name      String   @unique
    driveId   String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    tasks Task[]
    roles UserRole[]

    @@index([name])
}

model Task {
    id          String    @id @default(cuid())
    title       String
    description String?
    status      String    @default("todo")
    priority    String    @default("Med")
    dueDate     DateTime?
    notes       Json?
    role        String?

    departmentId String?
    assigneeId   String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
    assignee   User?       @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

    @@index([status])
    @@index([departmentId])
    @@index([assigneeId])
}

model UserRole {
    id           String   @id @default(cuid())
    userId       String
    role         String
    departmentId String?
    createdAt    DateTime @default(now())

    // Relations
    user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

    @@unique([userId, departmentId, role])
    @@index([userId])
    @@index([departmentId])
}

// ============================================
// ANNOUNCEMENTS MODULE
// ============================================

model Announcement {
    id       String @id @default(cuid())
    title    String
    content  String
    priority String @default("Normal")
    category String @default("company-news")

    // Event-specific fields
    eventDate     DateTime?
    eventLocation String?
    birthdayDate  DateTime?

    isImportant Boolean @default(false)
    authorId    String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    author   User?                 @relation(fields: [authorId], references: [id], onDelete: SetNull)
    likes    AnnouncementLike[]
    comments AnnouncementComment[]
    rsvps    AnnouncementRSVP[]

    @@index([createdAt])
    @@index([category])
    @@index([isImportant])
}

model AnnouncementLike {
    id             String   @id @default(cuid())
    announcementId String
    userId         String
    createdAt      DateTime @default(now())

    // Relations
    announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([announcementId, userId])
    @@index([announcementId])
    @@index([userId])
}

model AnnouncementComment {
    id             String   @id @default(cuid())
    announcementId String
    authorId       String
    text           String
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    // Relations
    announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
    author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

    @@index([announcementId])
    @@index([authorId])
}

model AnnouncementRSVP {
    id             String   @id @default(cuid())
    announcementId String
    userId         String
    status         String   @default("going")
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    // Relations
    announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([announcementId, userId])
    @@index([announcementId])
    @@index([userId])
}

// ============================================
// DAILY LOGS MODULE
// ============================================

model DailyLog {
    id          String   @id @default(cuid())
    content     String
    date        DateTime @default(now())
    department  String
    status      String   @default("in-progress")
    hoursLogged Float    @default(0)
    tasks       Json?
    authorId    String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    author User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
    likes  DailyLogLike[]

    @@index([authorId])
    @@index([date])
    @@index([department])
    @@index([status])
}

model DailyLogLike {
    id         String   @id @default(cuid())
    dailyLogId String
    userId     String
    createdAt  DateTime @default(now())

    // Relations
    dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([dailyLogId, userId])
    @@index([dailyLogId])
    @@index([userId])
}

// ============================================
// PAYROLL MODULE
// ============================================

model TimeEntry {
    id       String    @id @default(cuid())
    userId   String
    start    DateTime
    end      DateTime?
    duration Int?
    notes    String?

    createdAt DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([start])
}

model PayrollEvent {
    id          String   @id @default(cuid())
    title       String
    date        DateTime
    type        String
    description String?
    isBuiltIn   Boolean  @default(false)
    createdBy   String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([date])
    @@index([type])
}

model EmployeeProfile {
    id               String  @id @default(cuid())
    userId           String  @unique
    jobTitle         String?
    employmentType   String? @default("Full-Time")
    baseSalary       Float?  @default(0)
    currency         String  @default("PHP")
    paymentFrequency String  @default("Semi-Monthly")
    bankAccount      String?
    taxId            String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayrollPeriod {
    id          String    @id @default(cuid())
    startDate   DateTime
    endDate     DateTime
    payDate     DateTime?
    status      String    @default("draft")
    totalAmount Float     @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    payslips Payslip[]

    @@index([startDate])
    @@index([status])
}

model Payslip {
    id          String   @id @default(cuid())
    periodId    String
    userId      String
    grossPay    Float    @default(0)
    netPay      Float    @default(0)
    status      String   @default("draft")
    generatedAt DateTime @default(now())

    // Relations
    period PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
    user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    items  PayrollItem[]

    @@index([periodId])
    @@index([userId])
}

model PayrollItem {
    id          String   @id @default(cuid())
    payslipId   String
    type        String
    description String
    amount      Float
    createdAt   DateTime @default(now())

    // Relations
    payslip Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

    @@index([payslipId])
    @@index([type])
}

// ============================================
// CHAT MODULE
// ============================================

model Conversation {
    id        String   @id @default(cuid())
    type      String   @default("direct")
    name      String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    participants Participant[]
    messages     Message[]
}

model Participant {
    id             String   @id @default(cuid())
    conversationId String
    userId         String
    lastReadAt     DateTime @default(now())
    createdAt      DateTime @default(now())

    // Relations
    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([conversationId, userId])
    @@index([userId])
    @@index([conversationId])
}

model Message {
    id             String   @id @default(cuid())
    conversationId String
    senderId       String
    content        String
    attachment     String?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    // Relations
    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

    @@index([conversationId])
    @@index([senderId])
}
