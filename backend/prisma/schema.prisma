datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  name                 String?
  avatar               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  roles                UserRole[]
  tasks                Task[]
  announcements        Announcement[]
  announcementLikes    AnnouncementLike[]
  announcementComments AnnouncementComment[]
  announcementRsvps    AnnouncementRSVP[]
  dailyLogs            DailyLog[]
  dailyLogLikes        DailyLogLike[]
  timeEntries          TimeEntry[]
  messages             Message[]
  participations       Participant[]
  employeeProfile      EmployeeProfile?
  payslips             Payslip[]

  @@index([email])
}

model Department {
  id        String     @id @default(uuid())
  name      String     @unique
  driveId   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tasks     Task[]
  userRoles UserRole[]

  @@index([name])
}

model Task {
  id           String      @id @default(uuid())
  title        String
  description  String?
  status       String      @default("todo") // todo, inprogress, review, done
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  departmentId String?
  assignee     User?       @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId   String?
  role         String? // Specific role within department
  priority     String      @default("Med") // Low, Med, High
  dueDate      DateTime?
  notes        Json? // Stores array of { text, date }
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([departmentId])
  @@index([assigneeId])
}

model UserRole {
  id           String      @id @default(uuid())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  role         String
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId String?
  createdAt    DateTime    @default(now())

  @@unique([userId, departmentId, role])
  @@index([userId])
  @@index([departmentId])
}

model Announcement {
  id            String                @id @default(uuid())
  title         String
  content       String
  category      String                @default("company-news") // company-news, shoutouts, events, birthdays
  priority      String                @default("Normal") // Normal, High, Critical
  isImportant   Boolean               @default(false) // Pinned on dashboard
  author        User?                 @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId      String?
  eventDate     DateTime? // For events category
  eventLocation String? // For events category
  birthdayDate  DateTime? // For birthdays category
  likes         AnnouncementLike[]
  comments      AnnouncementComment[]
  rsvps         AnnouncementRSVP[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([createdAt])
  @@index([category])
  @@index([isImportant])
}

model AnnouncementLike {
  id             String       @id @default(uuid())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
}

model AnnouncementComment {
  id             String       @id @default(uuid())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId       String
  text           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([announcementId])
  @@index([authorId])
}

model AnnouncementRSVP {
  id             String       @id @default(uuid())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  status         String       @default("going") // going, maybe, not-going
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
}

model DailyLog {
  id          String         @id @default(uuid())
  content     String
  date        DateTime       @default(now())
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String
  department  String // Department name
  status      String         @default("in-progress") // completed, in-progress, blocked
  hoursLogged Float          @default(0)
  tasks       Json? // Array of {id, text, completed}
  likes       DailyLogLike[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([authorId])
  @@index([date])
  @@index([department])
  @@index([status])
}

model DailyLogLike {
  id         String   @id @default(uuid())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime @default(now())

  @@unique([dailyLogId, userId])
  @@index([dailyLogId])
  @@index([userId])
}

model TimeEntry {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  start     DateTime
  end       DateTime?
  duration  Int? // minutes
  notes     String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([start])
}

model PayrollEvent {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  type        String // payday, holiday, deadline, meeting, other
  description String?
  createdBy   String? // User ID who created custom events
  isBuiltIn   Boolean  @default(false) // Distinguish built-in vs custom events
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([type])
}

model Conversation {
  id        String   @id @default(uuid())
  type      String   @default("direct") // direct, group, channel
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  participants Participant[]
}

model Participant {
  id             String       @id @default(uuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  lastReadAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String       @id @default(uuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId       String
  content        String
  attachment     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
  @@index([senderId])
}

model EmployeeProfile {
  id               String   @id @default(uuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String   @unique
  jobTitle         String?
  employmentType   String?  @default("Full-Time") // Full-Time, Part-Time, Contractor
  baseSalary       Float?   @default(0) // or hourly rate
  currency         String   @default("PHP")
  paymentFrequency String   @default("Semi-Monthly") // Weekly, Semi-Monthly, Monthly
  bankAccount      String?
  taxId            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PayrollPeriod {
  id          String    @id @default(uuid())
  startDate   DateTime
  endDate     DateTime
  payDate     DateTime?
  status      String    @default("draft") // draft, processing, completed, paid
  totalAmount Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payslips    Payslip[]

  @@index([startDate])
  @@index([status])
}

model Payslip {
  id          String        @id @default(uuid())
  period      PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  periodId    String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  grossPay    Float         @default(0)
  netPay      Float         @default(0)
  status      String        @default("draft") // draft, sent, paid
  generatedAt DateTime      @default(now())
  items       PayrollItem[]

  @@index([periodId])
  @@index([userId])
}

model PayrollItem {
  id          String   @id @default(uuid())
  payslip     Payslip  @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  payslipId   String
  type        String // earning, deduction, tax, bonus, reimbursement
  description String
  amount      Float
  createdAt   DateTime @default(now())

  @@index([payslipId])
  @@index([type])
}
